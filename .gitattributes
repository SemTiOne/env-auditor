# Normalize line endings across platforms
* text=auto
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.sh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.whl binary
*.tar.gz binary
*.zip binary